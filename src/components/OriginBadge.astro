---
interface Props {
    origin: 'authentique' | 'assiste' | 'genere';
}

const { origin } = Astro.props;

const config = {
    authentique: {
        label: 'Authentique',
        symbol: '✦',
        title: 'Écrit entièrement par mirfou, sans assistance IA',
    },
    assiste: {
        label: 'Assisté',
        symbol: '◈',
        title: 'Écrit par mirfou avec assistance IA (structure, relecture ou suggestions)',
    },
    genere: {
        label: 'Généré',
        symbol: '◇',
        title: 'Contenu généré par IA, édité et validé par mirfou',
    },
};

const { label, symbol, title } = config[origin];
---

<span class={`badge badge-${origin}`} title={title}>
    <span class="badge-symbol">{symbol}</span>
    <span class="badge-label">{label}</span>
</span>

<style>
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.72rem;
        font-family: var(--font-mono);
        border: 1px solid;
        cursor: help;
        transition: opacity 0.2s;
    }

    .badge:hover { opacity: 0.8; }

    .badge-symbol { font-size: 0.65rem; }

    .badge-authentique {
        color: #4a7c5e;
        border-color: #4a7c5e40;
        background: #4a7c5e12;
    }

    .badge-assiste {
        color: #c8922a;
        border-color: #c8922a40;
        background: #c8922a12;
    }

    .badge-genere {
        color: var(--color-muted);
        border-color: var(--color-border);
        background: var(--color-surface);
    }
</style>
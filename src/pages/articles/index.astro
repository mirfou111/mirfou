---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import AntIcon from '../../components/AntIcon.astro';
import { BookOpen } from 'lucide-astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Articles — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <BookOpen size={22} color="var(--color-accent)" />
                <h1>Articles</h1>
            </div>
            <p class="page-sub">Réflexions longues, essais, pensées de fond.</p>
        </header>

        {articles.length === 0 ? (
            <p class="empty">Aucun article pour le moment. Bientôt...</p>
        ) : (
            <div class="list">
                {articles.map(article => (
                    <PostCard
                        title={article.data.title}
                        description={article.data.description}
                        pubDate={article.data.pubDate}
                        href={`/articles/${article.id}`}
                        tags={article.data.tags}
                        origin={article.data.origin}
                        body={article.body}
                        accentColor="#8b6340"
                    />
                ))}
            </div>
        )}
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 680px;
        margin: 0 auto;
        padding: 3rem 3rem 6rem;
    }

    .page-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 0.9rem;
        margin: 0;
    }

    .empty {
        color: var(--color-muted);
        font-style: italic;
        font-size: 0.9rem;
    }
</style>
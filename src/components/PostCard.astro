---
import { Calendar, Tag } from 'lucide-astro';

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    href: string;
    tags?: string[];
    color?: string;
}

const { title, description, pubDate, href, tags = [], color = 'var(--color-accent)' } = Astro.props;
---

<a href={href} class="card">
    <div class="card-inner">
        <h2 class="card-title" style={`color: ${color}`}>{title}</h2>
        <p class="card-desc">{description}</p>
        <div class="card-meta">
            <span class="card-date">
                <Calendar size={13} />
                <time>{pubDate.toLocaleDateString('fr-FR')}</time>
            </span>
            {tags.length > 0 && (
                <span class="card-tags">
                    <Tag size={13} />
                    {tags.slice(0, 3).map(tag => (
                        <span class="tag">{tag}</span>
                    ))}
                </span>
            )}
        </div>
    </div>
</a>

<style>
    .card {
        display: block;
        background-color: var(--color-surface);
        border-radius: 12px;
        padding: 1.5rem;
        transition: transform 0.2s, border-color 0.2s;
        border: 1px solid transparent;
    }

    .card:hover {
        transform: translateY(-2px);
        border-color: var(--color-accent-soft);
    }

    .card-title {
        font-family: var(--font-serif);
        font-size: 1.2rem;
        margin: 0 0 0.75rem;
        line-height: 1.3;
    }

    .card-desc {
        color: var(--color-muted);
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0 0 1.25rem;
    }

    .card-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .card-date {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        color: var(--color-muted);
        font-size: 0.8rem;
    }

    .card-tags {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        color: var(--color-muted);
        font-size: 0.8rem;
    }

    .tag {
        background-color: var(--color-bg);
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }
</style>
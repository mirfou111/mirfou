---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// On récupère les 3 derniers éléments de chaque collection
const articles = (await getCollection('articles')).slice(0, 3);
const contes = (await getCollection('contes')).slice(0, 3);
const reflexions = (await getCollection('reflexions')).slice(0, 3);
const tutos = (await getCollection('tutos')).slice(0, 3);
---

<BaseLayout title="mirfou — le jardin secret">
    <section class="hero">
        <h1>🐜 mirfou</h1>
        <p>Un jardin secret. Des articles, des réflexions, des tutos, et des contes.</p>
    </section>

    <section class="section">
        <h2>✍️ Articles récents</h2>
        {articles.length === 0
            ? <p class="empty">Bientôt...</p>
            : articles.map(a => <a href={`/articles/${a.id}`}>{a.data.title}</a>)
        }
    </section>

    <section class="section">
        <h2>📖 Contes récents</h2>
        {contes.length === 0
            ? <p class="empty">Bientôt...</p>
            : contes.map(c => <a href={`/contes/${c.id}`}>{c.data.title}</a>)
        }
    </section>

    <section class="section">
        <h2>💡 Réflexions</h2>
        {reflexions.length === 0
            ? <p class="empty">Bientôt...</p>
            : reflexions.map(r => <a href={`/reflexions/${r.id}`}>{r.data.title}</a>)
        }
    </section>

    <section class="section">
        <h2>🔧 Tutos</h2>
        {tutos.length === 0
            ? <p class="empty">Bientôt...</p>
            : tutos.map(t => <a href={`/tutos/${t.id}`}>{t.data.title}</a>)
        }
    </section>
</BaseLayout>
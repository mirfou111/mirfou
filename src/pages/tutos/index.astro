---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Terminal } from 'lucide-astro';

const tutos = (await getCollection('tutos', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Tutos — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <Terminal size={22} color="#4a6a8b" />
                <h1>Tutos</h1>
            </div>
            <p class="page-sub">Guides pratiques et techniques.</p>
        </header>

        {tutos.length === 0 ? (
            <p class="empty">Aucun tuto pour le moment. Bientôt...</p>
        ) : (
            <div class="list">
                {tutos.map(tuto => (
                    <PostCard
                        title={tuto.data.title}
                        description={tuto.data.description}
                        pubDate={tuto.data.pubDate}
                        href={`/tutos/${tuto.id}`}
                        tags={tuto.data.tags}
                        origin={tuto.data.origin}
                        body={tuto.body}
                        accentColor="#4a6a8b"
                    />
                ))}
            </div>
        )}
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 680px;
        margin: 0 auto;
        padding: 3rem 3rem 6rem;
    }

    .page-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 0.9rem;
        margin: 0;
    }

    .empty {
        color: var(--color-muted);
        font-style: italic;
        font-size: 0.9rem;
    }
</style>
---
import AntIcon from './AntIcon.astro';
import OriginBadge from './OriginBadge.astro';
import { Calendar, Clock } from 'lucide-astro';
import { readingTime } from '../utils/readingTime';

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    href: string;
    tags?: string[];
    origin?: 'authentique' | 'assiste' | 'genere';
    body?: string;
    accentColor?: string;
}

const {
    title,
    description,
    pubDate,
    href,
    tags = [],
    origin = 'authentique',
    body,
    accentColor = 'var(--color-accent)',
} = Astro.props;

const readTime = readingTime(body);
---

<a href={href} class="card">
    <div class="card-header">
        <h2 class="card-title" style={`color: ${accentColor}`}>{title}</h2>
        <AntIcon size={12} class="card-ant" />
    </div>
    <p class="card-desc">{description}</p>
    <div class="card-footer">
        <div class="card-meta">
            <span class="meta-item">
                <Calendar size={12} />
                <time>{pubDate.toLocaleDateString('fr-FR')}</time>
            </span>
            <span class="meta-item">
                <Clock size={12} />
                <span>{readTime}</span>
            </span>
        </div>
        <div class="card-right">
            {tags.slice(0, 2).map(tag => (
                <span class="tag">{tag}</span>
            ))}
            <OriginBadge origin={origin} />
        </div>
    </div>
</a>

<style>
    .card {
        display: block;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--color-border);
        transition: all 0.2s;
        text-decoration: none;
    }

    .card:last-child { border-bottom: none; }

    .card:hover .card-title {
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.4rem;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.3;
        margin: 0;
        flex: 1;
    }

    .card-ant {
        color: var(--color-border);
        flex-shrink: 0;
        margin-top: 0.2rem;
        transition: color 0.2s;
    }

    .card:hover .card-ant {
        color: var(--color-accent);
    }

    .card-desc {
        font-size: 0.88rem;
        color: var(--color-muted);
        line-height: 1.6;
        margin-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .card-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.72rem;
        color: var(--color-muted);
        font-family: var(--font-mono);
    }

    .card-right {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .tag {
        font-size: 0.68rem;
        font-family: var(--font-mono);
        color: var(--color-muted);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
    }
</style>
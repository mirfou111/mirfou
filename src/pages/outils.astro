---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompteurTexte from '../components/outils/CompteurTexte.astro';
import GenerateurSlug from '../components/outils/GenerateurSlug.astro';
import Pomodoro from '../components/outils/Pomodoro.astro';
import MarkdownPreview from '../components/outils/MarkdownPreview.astro';
import PaletteMirfou from '../components/outils/PaletteMirfou.astro';
import { Wrench } from 'lucide-astro';

const outils = [
    { id: 'compteur', label: 'Compteur de texte' },
    { id: 'slug', label: 'Générateur de slug' },
    { id: 'pomodoro', label: 'Pomodoro' },
    { id: 'markdown', label: 'Markdown → HTML' },
    { id: 'palette', label: 'Palette mirfou' },
];
---

<BaseLayout title="Outils — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <Wrench size={22} color="var(--color-accent)" />
                <h1>Outils</h1>
            </div>
            <p class="page-sub">Petits outils utiles — tout tourne dans le navigateur, rien n'est envoyé nulle part.</p>
        </header>

        <!-- Mini sommaire -->
        <nav class="toc">
            {outils.map(o => (
                <a href={`#${o.id}`} class="toc-item">{o.label}</a>
            ))}
        </nav>

        <!-- Outils -->
        <div class="outils-list">
            <section id="compteur" class="outil-section">
                <CompteurTexte />
            </section>
            <section id="slug" class="outil-section">
                <GenerateurSlug />
            </section>
            <section id="pomodoro" class="outil-section">
                <Pomodoro />
            </section>
            <section id="markdown" class="outil-section">
                <MarkdownPreview />
            </section>
            <section id="palette" class="outil-section">
                <PaletteMirfou />
            </section>
        </div>
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 780px;
        margin: 0 auto;
        padding: 3rem 3rem 6rem;
    }

    .page-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 0.88rem;
        margin: 0;
    }

    .toc {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 3rem;
    }

    .toc-item {
        font-size: 0.78rem;
        font-family: var(--font-mono);
        color: var(--color-muted);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: 0.25rem 0.65rem;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .toc-item:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
    }

    .outils-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .outil-section {
        padding: 2.5rem 0;
        border-bottom: 1px solid var(--color-border);
    }

    .outil-section:last-child {
        border-bottom: none;
    }

    @media (max-width: 640px) {
        .page { padding: 2rem 1.5rem 4rem; }
    }
</style>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Brain } from 'lucide-astro';

const reflexions = (await getCollection('reflexions', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Réflexions — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <Brain size={22} color="#7a5e8b" />
                <h1>Réflexions</h1>
            </div>
            <p class="page-sub">Fragments, pensées courtes, instants.</p>
        </header>

        {reflexions.length === 0 ? (
            <p class="empty">Aucune réflexion pour le moment. Bientôt...</p>
        ) : (
            <div class="list">
                {reflexions.map(reflexion => (
                    <PostCard
                        title={reflexion.data.title}
                        description={reflexion.data.description}
                        pubDate={reflexion.data.pubDate}
                        href={`/reflexions/${reflexion.id}`}
                        tags={reflexion.data.tags}
                        origin={reflexion.data.origin}
                        body={reflexion.body}
                        accentColor="#7a5e8b"
                    />
                ))}
            </div>
        )}
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 680px;
        margin: 0 auto;
        padding: 3rem 3rem 6rem;
    }

    .page-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 0.9rem;
        margin: 0;
    }

    .empty {
        color: var(--color-muted);
        font-style: italic;
        font-size: 0.9rem;
    }
</style>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Scroll } from 'lucide-astro';

const reflexions = (await getCollection('reflexions', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Reflexions — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <Scroll size={28} color="#9e7c9e" />
                <h1>Reflexions</h1>
            </div>
            <p class="page-sub">Fragments, pensées courtes, instants.</p>
        </header>

        {reflexions.length === 0 ? (
            <p class="empty">Aucun conte pour le moment. Bientôt...</p>
        ) : (
            <ul class="grid">
                {reflexions.map(reflexion => (
                    <li>
                        <PostCard
                            title={reflexion.data.title}
                            description={reflexion.data.description}
                            pubDate={reflexion.data.pubDate}
                            href={`/reflexions/${reflexion.id}`}
                            tags={reflexion.data.tags}
                            color="#9e7c9e"
                        />
                    </li>
                ))}
            </ul>
        )}
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
    }

    .page-header {
        margin-bottom: 3rem;
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    h1 {
        font-family: var(--font-serif);
        font-size: 2.5rem;
        margin: 0;
        color: var(--color-text);
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 1rem;
        margin: 0;
    }

    .grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .empty {
        color: var(--color-muted);
        font-style: italic;
    }
</style>
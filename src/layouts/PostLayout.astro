---
import BaseLayout from './BaseLayout.astro';
import OriginBadge from '../components/OriginBadge.astro';
import StatusBadge from '../components/StatusBadge.astro';
import AntIcon from '../components/AntIcon.astro';
import { Calendar, Clock, Tag, ArrowLeft } from 'lucide-astro';
import { readingTime } from '../utils/readingTime';
import { getCollection } from 'astro:content';

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
    backHref: string;
    backLabel: string;
    origin?: 'authentique' | 'assiste' | 'genere';
    status?: 'graine' | 'pousse' | 'mature';
    relatedPosts?: string[];
    body?: string;
    headings?: { depth: number; slug: string; text: string }[];
}

const {
    title,
    description,
    pubDate,
    updatedDate,
    tags = [],
    backHref,
    backLabel,
    origin = 'authentique',
    status = 'mature',
    relatedPosts = [],
    body,
    headings = [],
} = Astro.props;

const readTime = readingTime(body);
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);

type RelatedItem = {
    title: string;
    href: string;
    section: string;
};

let resolvedRelated: RelatedItem[] = [];

if (relatedPosts.length > 0) {
    const [articles, contes, tutos, reflexions, recherches] = await Promise.all([
        getCollection('articles', ({ data }) => !data.draft),
        getCollection('contes', ({ data }) => !data.draft),
        getCollection('tutos', ({ data }) => !data.draft),
        getCollection('reflexions', ({ data }) => !data.draft),
        getCollection('recherches', ({ data }) => !data.draft),
    ]);

    const allItems = [
        ...articles.map(i => ({ ...i, section: 'articles' })),
        ...contes.map(i => ({ ...i, section: 'contes' })),
        ...tutos.map(i => ({ ...i, section: 'tutos' })),
        ...reflexions.map(i => ({ ...i, section: 'reflexions' })),
        ...recherches.map(i => ({ ...i, section: 'recherches' })),
    ];

    resolvedRelated = relatedPosts
        .map(ref => {
            const [section, id] = ref.split('/');
            const found = allItems.find(i => i.section === section && i.id === id);
            if (!found) return null;
            return {
                title: found.data.title,
                href: `/${found.section}/${found.id}`,
                section: found.section,
            };
        })
        .filter(Boolean) as RelatedItem[];
}
---

<BaseLayout title={`${title} — mirfou`} description={description}>
    <div class="post-page">

        <a href={backHref} class="back-link">
            <ArrowLeft size={14} />
            <span>{backLabel}</span>
        </a>

        <div class={`post-layout ${tocItems.length > 0 ? 'has-toc' : ''}`}>

            <div class="post-main">

                <header class="post-header">
                    <h1 class="post-title">{title}</h1>
                    <p class="post-desc">{description}</p>

                    <div class="post-meta">
                        <span class="meta-item">
                            <Calendar size={13} />
                            <time>{pubDate.toLocaleDateString('fr-FR', { dateStyle: 'long' })}</time>
                        </span>
                        <span class="meta-item">
                            <Clock size={13} />
                            <span>{readTime}</span>
                        </span>
                        {updatedDate && (
                            <span class="meta-item">
                                <span>Mis à jour le</span>
                                <time>{updatedDate.toLocaleDateString('fr-FR', { dateStyle: 'long' })}</time>
                            </span>
                        )}
                        <OriginBadge origin={origin} />
                        <StatusBadge status={status} />
                    </div>

                    {tags.length > 0 && (
                        <div class="post-tags">
                            <Tag size={13} />
                            {tags.map(tag => (
                                <a href={`/tags/${tag}`} class="tag">{tag}</a>
                            ))}
                        </div>
                    )}
                </header>

                <article class="post-content" data-pagefind-body>
                    <slot />
                </article>

                {resolvedRelated.length > 0 && (
                    <div class="related">
                        <p class="related-title">Dans le même jardin</p>
                        <ul class="related-list">
                            {resolvedRelated.map(item => (
                                <li>
                                    <a href={item.href} class="related-item">
                                        <AntIcon size={11} class="related-ant" />
                                        <span class="related-section">{item.section}</span>
                                        <span class="related-name">{item.title}</span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}

                <footer class="post-footer">
                    <div class="footer-ant">
                        <AntIcon size={16} />
                    </div>
                    <a href={backHref} class="back-link-bottom">
                        <ArrowLeft size={13} />
                        <span>Retour aux {backLabel}</span>
                    </a>
                </footer>

            </div>

            {tocItems.length > 0 && (
                <aside class="toc">
                    <p class="toc-title">Dans cet article</p>
                    <ul>
                        {tocItems.map(h => (
                            <li class={`depth-${h.depth}`}>
                                <a href={`#${h.slug}`}>{h.text}</a>
                            </li>
                        ))}
                    </ul>
                </aside>
            )}

        </div>
    </div>
</BaseLayout>

<style>
    .post-page {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2.5rem 3rem 6rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-muted);
        font-size: 0.82rem;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover { color: var(--color-accent); }

    .post-layout {
        display: grid;
        grid-template-columns: 1fr;
    }

    .post-layout.has-toc {
        grid-template-columns: 1fr 200px;
        gap: 4rem;
        align-items: start;
    }

    .post-header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--color-border);
    }

    .post-title {
        font-size: clamp(1.6rem, 4vw, 2.4rem);
        font-weight: 700;
        color: var(--color-text);
        line-height: 1.2;
        margin-bottom: 0.75rem;
    }

    .post-desc {
        color: var(--color-muted);
        font-size: 1rem;
        line-height: 1.7;
        margin-bottom: 1.25rem;
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        color: var(--color-muted);
        font-size: 0.78rem;
        font-family: var(--font-mono);
    }

    .post-tags {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        color: var(--color-muted);
    }

    .tag {
        font-size: 0.72rem;
        font-family: var(--font-mono);
        color: var(--color-muted);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .tag:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
    }

    .post-content {
        font-size: 1rem;
        line-height: 1.85;
        color: var(--color-text);
    }

    .post-content :global(h2),
    .post-content :global(h3) {
        font-weight: 700;
        color: var(--color-text);
        margin: 2.5rem 0 1rem;
        line-height: 1.3;
    }

    .post-content :global(h2) { font-size: 1.4rem; }
    .post-content :global(h3) { font-size: 1.1rem; }
    .post-content :global(p) { margin-bottom: 1.5rem; }

    .post-content :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .post-content :global(blockquote) {
        border-left: 2px solid var(--color-accent);
        margin: 2rem 0;
        padding: 0.5rem 0 0.5rem 1.5rem;
        color: var(--color-muted);
        font-style: italic;
    }

    .post-content :global(code) {
        font-family: var(--font-mono);
        font-size: 0.85em;
        background: var(--color-surface);
        color: var(--color-accent);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        border: 1px solid var(--color-border);
    }

    .post-content :global(pre) {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1.5rem 0;
    }

    .post-content :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        color: var(--color-text);
        font-size: 0.88rem;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .post-content :global(li) { margin-bottom: 0.4rem; }

    .post-content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.9rem;
    }

    .post-content :global(th),
    .post-content :global(td) {
        padding: 0.6rem 1rem;
        border: 1px solid var(--color-border);
        text-align: left;
    }

    .post-content :global(th) {
        background: var(--color-surface);
        color: var(--color-accent);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2.5rem 0;
    }

    .post-content :global(img) {
        width: 100%;
        border-radius: 8px;
        margin: 2rem 0;
    }

    /* Related */
    .related {
        margin-top: 3rem;
        padding: 1.25rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
    }

    .related-title {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-muted);
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .related-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .related-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--color-text);
        transition: color 0.2s;
    }

    .related-item:hover { color: var(--color-accent); }

    .related-ant {
        color: var(--color-accent);
        flex-shrink: 0;
        opacity: 0.5;
        transition: opacity 0.2s;
    }

    .related-item:hover .related-ant { opacity: 1; }

    .related-section {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--color-muted);
        background: var(--color-surface-2);
        border: 1px solid var(--color-border);
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        flex-shrink: 0;
    }

    .related-name {
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Footer */
    .post-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .footer-ant {
        color: var(--color-accent);
        opacity: 0.4;
    }

    .back-link-bottom {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-muted);
        font-size: 0.82rem;
        transition: color 0.2s;
    }

    .back-link-bottom:hover { color: var(--color-accent); }

    /* TOC */
    .toc {
        position: sticky;
        top: 2rem;
    }

    .toc-title {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-muted);
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .toc ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .toc a {
        font-size: 0.8rem;
        color: var(--color-muted);
        line-height: 1.4;
        transition: color 0.2s;
        display: block;
    }

    .toc a:hover { color: var(--color-accent); }

    .depth-3 { padding-left: 0.75rem; }
    .depth-3 a { font-size: 0.75rem; }

    /* Mobile */
    @media (max-width: 768px) {
        .post-page { padding: 2rem 1.5rem 4rem; }
        .post-layout.has-toc { grid-template-columns: 1fr; }
        .toc { display: none; }
    }
</style>
---
import { Home, BookOpen, Scroll, Terminal, Brain, User, Menu, X } from 'lucide-astro';

const navItems = [
    { href: '/articles', label: 'Articles', icon: BookOpen },
    { href: '/contes', label: 'Contes', icon: Scroll },
    { href: '/tutos', label: 'Tutos', icon: Terminal },
    { href: '/reflexions', label: 'Réflexions', icon: Brain },
    { href: '/about', label: 'About', icon: User },
];

const currentPath = Astro.url.pathname;
---

<header>
    <nav>
        <a href="/" class="logo">
            <Home size={20} />
            <span>mirfou</span>
        </a>

        <!-- Navigation desktop -->
        <ul class="nav-links">
            {navItems.map(({ href, label, icon: Icon }) => (
                <li>
                    <a 
                        href={href} 
                        class={currentPath.startsWith(href) ? 'active' : ''}
                    >
                        <Icon size={16} />
                        <span>{label}</span>
                    </a>
                </li>
            ))}
        </ul>

        <!-- Burger menu mobile -->
        <button class="burger" id="burger-btn" aria-label="Menu">
            <Menu size={24} id="icon-menu" />
            <X size={24} id="icon-close" style="display:none" />
        </button>
    </nav>

    <!-- Menu mobile -->
    <ul class="mobile-menu" id="mobile-menu">
        {navItems.map(({ href, label, icon: Icon }) => (
            <li>
                <a href={href} class={currentPath.startsWith(href) ? 'active' : ''}>
                    <Icon size={18} />
                    <span>{label}</span>
                </a>
            </li>
        ))}
    </ul>
</header>

<script>
    const btn = document.getElementById('burger-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    btn?.addEventListener('click', () => {
        const isOpen = menu?.classList.toggle('open');
        if (iconMenu) iconMenu.style.display = isOpen ? 'none' : 'block';
        if (iconClose) iconClose.style.display = isOpen ? 'block' : 'none';
    });
</script>

<style>
    header {
        position: sticky;
        top: 0;
        z-index: 100;
        background-color: var(--color-bg);
        border-bottom: 1px solid var(--color-surface);
        padding: 0 1.5rem;
    }

    nav {
        max-width: 900px;
        margin: 0 auto;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text);
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 700;
    }

    .logo:hover {
        color: var(--color-accent);
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .nav-links a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-muted);
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--color-accent);
        background-color: var(--color-surface);
    }

    .burger {
        display: none;
        background: none;
        border: none;
        color: var(--color-text);
        cursor: pointer;
        padding: 0.5rem;
    }

    .mobile-menu {
        display: none;
        flex-direction: column;
        list-style: none;
        margin: 0;
        padding: 1rem 0;
        border-top: 1px solid var(--color-surface);
    }

    .mobile-menu.open {
        display: flex;
    }

    .mobile-menu a {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-muted);
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.2s;
    }

    .mobile-menu a:hover,
    .mobile-menu a.active {
        color: var(--color-accent);
        background-color: var(--color-surface);
    }

    @media (max-width: 768px) {
        .nav-links {
            display: none;
        }
        .burger {
            display: block;
        }
    }
</style>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { BookOpen } from 'lucide-astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Articles — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <BookOpen size={28} color="var(--color-accent)" />
                <h1>Articles</h1>
            </div>
            <p class="page-sub">Réflexions longues, essais, pensées de fond.</p>
        </header>

        {articles.length === 0 ? (
            <p class="empty">Aucun article pour le moment. Bientôt...</p>
        ) : (
            <ul class="grid">
                {articles.map(article => (
                    <li>
                        <PostCard
                            title={article.data.title}
                            description={article.data.description}
                            pubDate={article.data.pubDate}
                            href={`/articles/${article.id}`}
                            tags={article.data.tags}
                            color="#c8922a"
                        />
                    </li>
                ))}
            </ul>
        )}
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
    }

    .page-header {
        margin-bottom: 3rem;
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    h1 {
        font-family: var(--font-serif);
        font-size: 2.5rem;
        margin: 0;
        color: var(--color-text);
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 1rem;
        margin: 0;
    }

    .grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .empty {
        color: var(--color-muted);
        font-style: italic;
    }
</style>
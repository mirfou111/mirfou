---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { BookOpen, Scroll, Terminal, Brain, ArrowRight } from 'lucide-astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const contes = (await getCollection('contes', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const reflexions = (await getCollection('reflexions', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const tutos = (await getCollection('tutos', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const sections = [
    { label: 'Articles', href: '/articles', icon: BookOpen, items: articles, color: '#c8922a' },
    { label: 'Contes', href: '/contes', icon: Scroll, items: contes, color: '#7c9e6f' },
    { label: 'Tutos', href: '/tutos', icon: Terminal, items: tutos, color: '#6f8fae' },
    { label: 'Réflexions', href: '/reflexions', icon: Brain, items: reflexions, color: '#9e7c9e' },
];
---

<BaseLayout title="mirfou — le jardin secret">

    <!-- Hero -->
    <section class="hero">
        <div class="hero-inner">
            <p class="hero-eyebrow">Bienvenue dans le jardin</p>
            <h1 class="hero-title">mirfou</h1>
            <p class="hero-sub">
                Un espace intime pour partager des articles, des réflexions,
                des tutos et des contes. Construit grain par grain, comme la fourmi.
            </p>
        </div>
    </section>

    <!-- Sections -->
    <div class="sections-grid">
        {sections.map(({ label, href, icon: Icon, items, color }) => (
            <section class="section-block">
                <div class="section-header">
                    <div class="section-title-group">
                        <Icon size={20} style={`color: ${color}`} />
                        <h2 class="section-title" style={`color: ${color}`}>{label}</h2>
                    </div>
                    <a href={href} class="see-all">
                        <span>Voir tout</span>
                        <ArrowRight size={14} />
                    </a>
                </div>

                {items.length === 0 ? (
                    <p class="empty">Bientôt...</p>
                ) : (
                    <ul class="item-list">
                        {items.map(item => (
                            <li>
                                <a href={`${href}/${item.id}`} class="item-link">
                                    <span class="item-title">{item.data.title}</span>
                                    <time class="item-date">
                                        {item.data.pubDate.toLocaleDateString('fr-FR')}
                                    </time>
                                </a>
                            </li>
                        ))}
                    </ul>
                )}
            </section>
        ))}
    </div>

</BaseLayout>

<style>
    /* Hero */
    .hero {
        border-bottom: 1px solid var(--color-surface);
        padding: 5rem 1.5rem 4rem;
    }

    .hero-inner {
        max-width: 900px;
        margin: 0 auto;
    }

    .hero-eyebrow {
        color: var(--color-accent);
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin: 0 0 1rem;
    }

    .hero-title {
        font-family: var(--font-serif);
        font-size: clamp(3rem, 8vw, 6rem);
        color: var(--color-text);
        margin: 0 0 1.5rem;
        line-height: 1;
    }

    .hero-sub {
        color: var(--color-muted);
        font-size: 1.1rem;
        max-width: 520px;
        line-height: 1.7;
        margin: 0;
    }

    /* Grid sections */
    .sections-grid {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    @media (max-width: 640px) {
        .sections-grid {
            grid-template-columns: 1fr;
        }
    }

    .section-block {
        background-color: var(--color-surface);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .section-title-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .section-title {
        font-family: var(--font-serif);
        font-size: 1.1rem;
        margin: 0;
    }

    .see-all {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        color: var(--color-muted);
        font-size: 0.8rem;
        transition: color 0.2s;
    }

    .see-all:hover {
        color: var(--color-accent);
    }

    /* Items */
    .item-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .item-link {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        color: var(--color-text);
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    .item-link:hover {
        color: var(--color-accent);
    }

    .item-title {
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-date {
        color: var(--color-muted);
        font-size: 0.75rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .empty {
        color: var(--color-muted);
        font-size: 0.85rem;
        font-style: italic;
        margin: 0;
    }
</style>
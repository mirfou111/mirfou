---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
    const tutos = await getCollection('tutos', ({ data }) => !data.draft);
    return tutos.map(tuto => ({
        params: { slug: tuto.id },
        props: { tuto },
    }));
}

const { tuto } = Astro.props;
const { Content } = await render(tuto);
---

<PostLayout
    title={tuto.data.title}
    description={tuto.data.description}
    pubDate={tuto.data.pubDate}
    updatedDate={tuto.data.updatedDate}
    tags={tuto.data.tags}
    backHref="/tutos"
    backLabel="Tutos"
    accentColor="#6f8fae"
>
    <Content />
</PostLayout>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Tag } from 'lucide-astro';

// Récupérer tous les posts de toutes les collections
const [articles, contes, tutos, reflexions, recherches] = await Promise.all([
    getCollection('articles', ({ data }) => !data.draft),
    getCollection('contes', ({ data }) => !data.draft),
    getCollection('tutos', ({ data }) => !data.draft),
    getCollection('reflexions', ({ data }) => !data.draft),
    getCollection('recherches', ({ data }) => !data.draft),
]);

const allPosts = [...articles, ...contes, ...tutos, ...reflexions, ...recherches];

// Compter les occurrences de chaque tag
const tagMap = new Map<string, number>();

allPosts.forEach(post => {
    (post.data.tags ?? []).forEach(tag => {
        tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
    });
});

// Trier par fréquence décroissante puis alphabétiquement
const tags = [...tagMap.entries()]
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const totalTags = tags.length;
const totalPosts = allPosts.length;
---

<BaseLayout title="Tags — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <Tag size={22} color="var(--color-accent)" />
                <h1>Tags</h1>
            </div>
            <p class="page-sub">
                {totalTags} tags · {totalPosts} contenus indexés
            </p>
        </header>

        <div class="tag-cloud">
            {tags.map(([tag, count]) => (
                <a
                    href={`/tags/${tag}`}
                    class="tag-item"
                    data-count={count}
                    title={`${count} contenu${count > 1 ? 's' : ''}`}
                >
                    <span class="tag-name">{tag}</span>
                    <span class="tag-count">{count}</span>
                </a>
            ))}
        </div>
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 680px;
        margin: 0 auto;
        padding: 3rem 3rem 6rem;
    }

    .page-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 0.9rem;
        margin: 0;
        font-family: var(--font-mono);
    }

    .tag-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .tag-item {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.75rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .tag-item:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-surface-2);
    }

    .tag-name {
        font-size: 0.85rem;
        color: var(--color-text);
        transition: color 0.2s;
    }

    .tag-item:hover .tag-name {
        color: var(--color-accent);
    }

    .tag-count {
        font-size: 0.68rem;
        font-family: var(--font-mono);
        color: var(--color-muted);
        background: var(--color-surface-2);
        border: 1px solid var(--color-border);
        padding: 0.05rem 0.35rem;
        border-radius: 3px;
        transition: all 0.2s;
    }

    .tag-item:hover .tag-count {
        color: var(--color-accent);
        border-color: var(--color-accent);
    }

    @media (max-width: 640px) {
        .page { padding: 2rem 1.5rem 4rem; }
    }
</style>
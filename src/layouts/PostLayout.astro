---
import BaseLayout from './BaseLayout.astro';
import { Calendar, Tag, ArrowLeft } from 'lucide-astro';

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
    backHref: string;
    backLabel: string;
    accentColor?: string;
}

const {
    title,
    description,
    pubDate,
    updatedDate,
    tags = [],
    backHref,
    backLabel,
    accentColor = 'var(--color-accent)',
} = Astro.props;
---

<BaseLayout title={`${title} — mirfou`} description={description}>
    <div class="post-page">

        <!-- Retour -->
        <a href={backHref} class="back-link">
            <ArrowLeft size={16} />
            <span>{backLabel}</span>
        </a>

        <!-- Header article -->
        <header class="post-header">
            <h1 class="post-title" style={`color: ${accentColor}`}>{title}</h1>
            <p class="post-desc">{description}</p>
            <div class="post-meta">
                <span class="meta-item">
                    <Calendar size={14} />
                    <time>{pubDate.toLocaleDateString('fr-FR', { dateStyle: 'long' })}</time>
                </span>
                {updatedDate && (
                    <span class="meta-item">
                        <span>Mis à jour le</span>
                        <time>{updatedDate.toLocaleDateString('fr-FR', { dateStyle: 'long' })}</time>
                    </span>
                )}
                {tags.length > 0 && (
                    <span class="meta-item">
                        <Tag size={14} />
                        {tags.map(tag => (
                            <span class="tag">{tag}</span>
                        ))}
                    </span>
                )}
            </div>
        </header>

        <!-- Contenu MDX -->
        <article class="post-content">
            <slot />
        </article>

    </div>
</BaseLayout>

<style>
    .post-page {
        max-width: 680px;
        margin: 0 auto;
        padding: 2rem 1.5rem 6rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-muted);
        font-size: 0.85rem;
        margin-bottom: 2.5rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--color-accent);
    }

    .post-header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--color-surface);
    }

    .post-title {
        font-family: var(--font-serif);
        font-size: clamp(1.8rem, 5vw, 2.8rem);
        line-height: 1.2;
        margin: 0 0 1rem;
    }

    .post-desc {
        color: var(--color-muted);
        font-size: 1.05rem;
        line-height: 1.7;
        margin: 0 0 1.5rem;
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--color-muted);
        font-size: 0.82rem;
    }

    .tag {
        background-color: var(--color-surface);
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }

    /* Typographie du contenu */
    .post-content {
        color: var(--color-text);
        font-size: 1.05rem;
        line-height: 1.8;
    }

    .post-content :global(h1),
    .post-content :global(h2),
    .post-content :global(h3) {
        font-family: var(--font-serif);
        color: var(--color-text);
        margin: 2.5rem 0 1rem;
        line-height: 1.3;
    }

    .post-content :global(h2) { font-size: 1.6rem; }
    .post-content :global(h3) { font-size: 1.25rem; }

    .post-content :global(p) {
        margin: 0 0 1.5rem;
    }

    .post-content :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .post-content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        margin: 2rem 0;
        padding: 0.5rem 0 0.5rem 1.5rem;
        color: var(--color-muted);
        font-style: italic;
    }

    .post-content :global(code) {
        background-color: var(--color-surface);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.88em;
        color: var(--color-accent);
    }

    .post-content :global(pre) {
        background-color: var(--color-surface);
        padding: 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5rem 0;
    }

    .post-content :global(pre code) {
        background: none;
        padding: 0;
        color: var(--color-text);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
        padding-left: 1.5rem;
        margin: 0 0 1.5rem;
    }

    .post-content :global(li) {
        margin-bottom: 0.5rem;
    }

    .post-content :global(img) {
        width: 100%;
        border-radius: 8px;
        margin: 2rem 0;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px solid var(--color-surface);
        margin: 3rem 0;
    }
</style>
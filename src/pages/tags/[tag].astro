---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Tag as TagIcon, ArrowLeft } from 'lucide-astro';

export async function getStaticPaths() {
    const [articles, contes, tutos, reflexions, recherches] = await Promise.all([
        getCollection('articles', ({ data }) => !data.draft),
        getCollection('contes', ({ data }) => !data.draft),
        getCollection('tutos', ({ data }) => !data.draft),
        getCollection('reflexions', ({ data }) => !data.draft),
        getCollection('recherches', ({ data }) => !data.draft),
    ]);

    const allPosts = [
        ...articles.map(p => ({ ...p, section: 'articles' })),
        ...contes.map(p => ({ ...p, section: 'contes' })),
        ...tutos.map(p => ({ ...p, section: 'tutos' })),
        ...reflexions.map(p => ({ ...p, section: 'reflexions' })),
        ...recherches.map(p => ({ ...p, section: 'recherches' })),
    ];

    // Collecter tous les tags uniques
    const allTags = [...new Set(allPosts.flatMap(p => p.data.tags ?? []))];

    return allTags.map(tag => ({
        params: { tag },
        props: {
            tag,
            posts: allPosts
                .filter(p => p.data.tags?.includes(tag))
                .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
        },
    }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} — mirfou`}>
    <div class="page">
        <a href="/tags" class="back-link">
            <ArrowLeft size={14} />
            <span>Tous les tags</span>
        </a>

        <header class="page-header">
            <div class="page-title-group">
                <TagIcon size={18} color="var(--color-accent)" />
                <h1>{tag}</h1>
            </div>
            <p class="page-sub">
                {posts.length} contenu{posts.length > 1 ? 's' : ''}
            </p>
        </header>

        <div class="list">
            {posts.map(post => (
                <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    href={`/${post.section}/${post.id}`}
                    tags={post.data.tags}
                    origin={post.data.origin}
                    body={post.body}
                />
            ))}
        </div>
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 680px;
        margin: 0 auto;
        padding: 2.5rem 3rem 6rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-muted);
        font-size: 0.82rem;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover { color: var(--color-accent); }

    .page-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 0.9rem;
        margin: 0;
        font-family: var(--font-mono);
    }

    @media (max-width: 640px) {
        .page { padding: 2rem 1.5rem 4rem; }
    }
</style>
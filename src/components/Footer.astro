---
import { Github } from 'lucide-astro';

const currentYear = new Date().getFullYear();
---

<footer>
    <div class="footer-inner">
        <p class="credit">
            Cultivé avec soin par <span class="name">mirfou</span> · {currentYear}
        </p>
        
        <a 
            href="https://github.com/mirfou111/mirfou"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="github-link"
        >
            <Github size={18} />
        </a>
    </div>
</footer>

<style>
    footer {
        margin-top: 6rem;
        border-top: 1px solid var(--color-surface);
        padding: 2rem 1.5rem;
    }

    .footer-inner {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .credit {
        color: var(--color-muted);
        font-size: 0.85rem;
        margin: 0;
    }

    .name {
        color: var(--color-accent);
        font-family: var(--font-serif);
    }

    a {
        color: var(--color-muted);
        transition: color 0.2s;
    }

    a:hover {
        color: var(--color-accent);
    }
</style>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Scroll } from 'lucide-astro';

const tutos = (await getCollection('tutos', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Tutos — mirfou">
    <div class="page">
        <header class="page-header">
            <div class="page-title-group">
                <Scroll size={28} color="#6f8fae" />
                <h1>Tutos</h1>
            </div>
            <p class="page-sub">Guides pratiques et techniques.</p>
        </header>

        {tutos.length === 0 ? (
            <p class="empty">Aucun conte pour le moment. Bientôt...</p>
        ) : (
            <ul class="grid">
                {tutos.map(tuto => (
                    <li>
                        <PostCard
                            title={tuto.data.title}
                            description={tuto.data.description}
                            pubDate={tuto.data.pubDate}
                            href={`/tutos/${tuto.id}`}
                            tags={tuto.data.tags}
                            color="#6f8fae"
                        />
                    </li>
                ))}
            </ul>
        )}
    </div>
</BaseLayout>

<style>
    .page {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
    }

    .page-header {
        margin-bottom: 3rem;
    }

    .page-title-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    h1 {
        font-family: var(--font-serif);
        font-size: 2.5rem;
        margin: 0;
        color: var(--color-text);
    }

    .page-sub {
        color: var(--color-muted);
        font-size: 1rem;
        margin: 0;
    }

    .grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .empty {
        color: var(--color-muted);
        font-style: italic;
    }
</style>